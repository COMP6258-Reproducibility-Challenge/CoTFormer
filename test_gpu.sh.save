#!/bin/bash
#SBATCH --job-name=gpu_test
#SBATCH --partition=ecsstudents_l4
#SBATCH --nodes=1
#SBATCH --gres=gpu:1
#SBATCH --ntasks=1
#SBATCH --time=00:05:00
#SBATCH --output=gpu_test_%j.out

source ~/.bash_aliases
module load conda
eval "$(conda shell.bash hook)"

conda_activate "$Conda
 
c v nm  fdsadb 
python test_gpu.py
